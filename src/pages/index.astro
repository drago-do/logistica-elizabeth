---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Consolidación de Carga Premium">
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="container hero-content fade-in">
        <h1>Maximiza tu Eficiencia Logística con Consolidación Inteligente</h1>
        <p>
          Optimiza tu cadena de suministro con nuestro sistema robusto de carga
          LTL/Grupaje. Reducción drástica de costos y visibilidad total en
          tiempo real.
        </p>
        <div class="hero-actions">
          <a href="#cotiza" class="btn btn-primary">Cotiza ahora</a>
          <a
            href="#tecnologia"
            class="btn btn-outline"
            style="color: white; border-color: white;">Ver tecnología</a
          >
        </div>
      </div>
    </section>

    <!-- Social Proof -->
    <section class="social-proof">
      <div class="container">
        <p class="section-tag">Confian en nosotros</p>
        <div class="logo-cloud">
          <div class="mock-logo">GLOBAL TECH</div>
          <div class="mock-logo">MEX-LOG</div>
          <div class="mock-logo">FAST-SHIP</div>
          <div class="mock-logo">EURO-TRANS</div>
          <div class="mock-logo">NORDIC-SUPPLY</div>
        </div>
      </div>
    </section>

    <!-- Value Proposition -->
    <section id="beneficios" class="benefits">
      <div class="container text-center">
        <h2 class="section-title">¿Por qué elegir nuestra consolidación?</h2>
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">📉</div>
            <h3>Ahorro Drástico</h3>
            <p>
              Reduce hasta un 40% en costos operativos mediante el
              aprovechamiento máximo de espacios de carga.
            </p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">🛡️</div>
            <h3>Seguridad Total</h3>
            <p>
              Estándares internacionales de manipulación y estiba. Tu carga está
              protegida de extremo a extremo.
            </p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">⏱️</div>
            <h3>Frecuencia Garantizada</h3>
            <p>
              Salidas diarias programadas. No esperes a que el camión se llene,
              nosotros ya tenemos la red lista.
            </p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">🌐</div>
            <h3>Visibilidad 24/7</h3>
            <p>
              Rastreo satelital y avisos automáticos. Sabrás dónde está tu
              pallet en cada segundo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it Works -->
    <section id="como-funciona" class="how-it-works bg-alt">
      <div class="container">
        <div class="how-content">
          <div class="how-text">
            <h2 class="section-title">Proceso Simplificado</h2>
            <div class="steps">
              <div class="step">
                <div class="step-num">01</div>
                <div class="step-info">
                  <h3>Recolección Programada</h3>
                  <p>
                    Recogemos tu mercancía en tu planta o almacén con
                    puntualidad milimétrica.
                  </p>
                </div>
              </div>
              <div class="step">
                <div class="step-num">02</div>
                <div class="step-info">
                  <h3>Consolidación en Hub</h3>
                  <p>
                    Integramos tu carga en nuestras rutas optimizadas mediante
                    algoritmos de espacio.
                  </p>
                </div>
              </div>
              <div class="step">
                <div class="step-num">03</div>
                <div class="step-info">
                  <h3>Entrega Final y Evidencia</h3>
                  <p>
                    Entrega en destino con confirmación digital inmediata y
                    fotos de evidencia.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="how-image">
            <img
              src="./almacen.avif"
              alt="Warehouse operations"
              class="img-fluid rounded shadow"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Technology -->
    <section id="tecnologia" class="tech-section">
      <div class="container">
        <div class="tech-grid">
          <div class="tech-card glass">
            <img
              src="/logistics_dashboard_mockup.jpg"
              alt="Dashboard Preview"
              class="tech-img"
            />
            <div class="tech-content">
              <h2 class="section-title">Tecnología estilo Samsara</h2>
              <p>
                No somos solo transporte, somos una plataforma tecnológica.
                Nuestro tablero de control te permite:
              </p>
              <ul class="tech-list">
                <li>Rastreo en tiempo real con precisión de 5 metros.</li>
                <li>Alertas inteligentes de desviación de ruta o retraso.</li>
                <li>
                  Acceso instantáneo a documentación (Carta Porte, Packing
                  List).
                </li>
                <li>Dashboard de analítica y KPIs de tus envíos.</li>
              </ul>
              <a href="/dashboard" class="btn btn-primary"
                >Explorar Dashboard Demo</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quotation Form -->
    <section id="cotiza" class="quote-section">
      <div class="container narrow">
        <div class="quote-card shadow-lg">
          <h2 class="text-center">Calcula tu Ahorro</h2>
          <p class="text-center text-muted">
            Obtén una cotización estimada en segundos.
          </p>

          <form class="quote-form">
            <div class="form-group">
              <label>Correo Corporativo</label>
              <input type="email" placeholder="ejemplo@empresa.com" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Origen</label>
                <select>
                  <option>CDMX</option>
                  <option>Monterrey</option>
                  <option>Guadalajara</option>
                  <option>Nuevo Laredo</option>
                </select>
              </div>
              <div class="form-group">
                <label>Destino</label>
                <select>
                  <option>Nuevo Laredo</option>
                  <option>Querétaro</option>
                  <option>Veracruz</option>
                  <option>San Luis Potosí</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Peso Total (kg)</label>
                <input type="number" placeholder="1000" />
              </div>
              <div class="form-group">
                <label>Dimensiones (Pallets)</label>
                <input type="number" placeholder="2" />
              </div>
            </div>

            <div class="quote-result" id="quoteResult" style="display: none;">
              <p>Precio Estimado:</p>
              <span class="price">$12,450.00 MXN</span>
              <p class="disclaimer">
                *Sujeto a cambios tras verificación física.
              </p>
            </div>

            <button type="button" class="btn btn-primary btn-block" id="calcBtn"
              >Calcular y Enviar Cotización</button
            >
          </form>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <div class="container narrow">
        <h2 class="section-title text-center">Preguntas Frecuentes</h2>
        <div class="accordion">
          <div class="accordion-item">
            <h3>¿Qué es la carga consolidada (LTL)?</h3>
            <p>
              Es un modelo donde tu mercancía comparte espacio en un camión con
              otros clientes, permitiéndote pagar solo por el espacio que
              ocupas.
            </p>
          </div>
          <div class="accordion-item">
            <h3>¿Cuáles son los tiempos de entrega?</h3>
            <p>
              Dependiendo de la ruta, nuestros tiempos oscilan entre 24 y 72
              horas para rutas nacionales principales.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials bg-alt">
      <div class="container text-center">
        <h2 class="section-title">Lo que dicen nuestros clientes</h2>
        <div class="testimonial-card shadow">
          <p>
            "La visibilidad que nos dan es impresionante. Redujimos nuestras
            incidencias en un 30% desde que migramos a su plataforma."
          </p>
          <div class="testimonial-user">
            <strong>Ing. Roberto Sánchez</strong>
            <span>Gerente Logística, Mex-Log Corp.</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Simple calculator logic for the prototype
    const calcBtn = document.getElementById("calcBtn");
    const quoteResult = document.getElementById("quoteResult");

    if (calcBtn) {
      calcBtn.addEventListener("click", () => {
        quoteResult.style.display = "block";
        calcBtn.textContent = "Cotización enviada a tu correo";
        calcBtn.style.backgroundColor = "var(--color-primary)";
        calcBtn.style.color = "white";
      });
    }
  </script>

  <style>
    .hero {
      height: 85vh;
      background-image: url("/logistics_hero_bg.jpg");
      background-size: cover;
      background-position: center;
      position: relative;
      display: flex;
      align-items: center;
      color: white;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        rgba(0, 26, 61, 0.9) 0%,
        rgba(0, 26, 61, 0.4) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 10;
      max-width: 800px;
    }

    .hero h1 {
      font-size: 3.5rem;
      color: white;
      margin-bottom: 1.5rem;
    }

    .hero p {
      font-size: 1.25rem;
      margin-bottom: 2.5rem;
      color: #d1d5db;
    }

    .hero-actions {
      display: flex;
      gap: 1.5rem;
    }

    .social-proof {
      padding: 3rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .section-tag {
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
    }

    .logo-cloud {
      display: flex;
      justify-content: space-around;
      align-items: center;
      flex-wrap: wrap;
      gap: 2rem;
      opacity: 0.6;
    }

    .mock-logo {
      font-weight: 800;
      font-size: 1.2rem;
      color: var(--color-primary);
      letter-spacing: -0.02em;
    }

    .section-title {
      margin-bottom: 3rem;
      font-size: 2.5rem;
      text-align: center;
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .benefit-card {
      padding: 2.5rem;
      background: white;
      border-radius: var(--radius-lg);
      transition: var(--transition);
      border: 1px solid transparent;
    }

    .benefit-card:hover {
      border-color: var(--color-accent);
      transform: translateY(-5px);
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
    }

    .benefit-icon {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
    }

    .bg-alt {
      background-color: var(--color-bg-alt);
    }

    .how-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .steps {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .step {
      display: flex;
      gap: 1.5rem;
    }

    .step-num {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--color-accent);
      opacity: 0.5;
    }

    .how-image img {
      width: 100%;
      border-radius: var(--radius-lg);
    }

    .tech-section {
      overflow: hidden;
    }

    .tech-card {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
      background: var(--color-primary) !important;
      color: white;
      padding: 4rem;
      border-radius: var(--radius-lg);
      align-items: center;
    }

    .tech-content h2 {
      color: white;
      text-align: left;
    }

    .tech-img {
      width: 100%;
      border-radius: var(--radius-md);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .tech-list {
      list-style: none;
      margin: 2rem 0;
    }

    .tech-list li {
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .tech-list li::before {
      content: "✓";
      color: var(--color-accent);
      font-weight: bold;
    }

    .quote-section {
      background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
    }

    .narrow {
      max-width: 800px;
    }

    .quote-card {
      background: white;
      padding: 3rem;
      border-radius: var(--radius-lg);
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--color-text-muted);
    }

    input,
    select {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      font-family: inherit;
    }

    .btn-block {
      width: 100%;
      margin-top: 1rem;
    }

    .quote-result {
      background: var(--color-bg-alt);
      padding: 1.5rem;
      border-radius: var(--radius-md);
      border-left: 4px solid var(--color-accent);
      margin: 2rem 0;
      text-align: center;
    }

    .price {
      font-size: 2rem;
      font-weight: 800;
      color: var(--color-primary);
      display: block;
      margin: 0.5rem 0;
    }

    .disclaimer {
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    .accordion {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .accordion-item {
      background: white;
      padding: 1.5rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
    }

    .testimonial-card {
      max-width: 600px;
      margin: 0 auto;
      background: white;
      padding: 3rem;
      border-radius: var(--radius-lg);
      position: relative;
    }

    .testimonial-card p {
      font-size: 1.25rem;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .text-center {
      text-align: center;
    }

    @media (max-width: 968px) {
      .hero h1 {
        font-size: 2.5rem;
      }
      .how-content,
      .tech-card {
        grid-template-columns: 1fr;
      }
      .tech-card {
        padding: 2rem;
      }
    }
  </style>
</Layout>
