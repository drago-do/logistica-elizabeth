---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Premium Freight Consolidation" description="Strategic solution for high-volume shipping with technological visibility." lang="en">
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-container parallax-bg">
        <img
          src="/logistics_hero_bg.jpg"
          alt="Logistics Background"
          class="hero-bg-image"
        />
      </div>
      <div class="hero-overlay"></div>
      <div class="container hero-content reveal">
        <h1>Maximize Your Logistics Efficiency with Smart Consolidation</h1>
        <p>
          Optimize your supply chain with our robust LTL/Groupage load system. Drastic cost reduction and total real-time visibility.
        </p>
        <div class="hero-actions">
          <a href="#cotiza" class="btn btn-primary">Quote now</a>
          <a
            href="#tecnologia"
            class="btn btn-outline"
            style="color: white; border-color: white;">View technology</a
          >
        </div>
      </div>
    </section>

    <!-- Social Proof -->
    <section class="social-proof">
      <div class="container">
        <p class="section-tag">Trusted by</p>
        <div class="logo-cloud">
          <div class="mock-logo">GLOBAL TECH</div>
          <div class="mock-logo">MEX-LOG</div>
          <div class="mock-logo">FAST-SHIP</div>
          <div class="mock-logo">EURO-TRANS</div>
          <div class="mock-logo">NORDIC-SUPPLY</div>
        </div>
      </div>
    </section>

    <!-- Value Proposition -->
    <section id="beneficios" class="benefits">
      <div class="container text-center">
        <h2 class="section-title reveal">
          Why choose our consolidation?
        </h2>
        <div class="benefits-grid">
          <div class="benefit-card reveal delay-100">
            <div class="benefit-icon">
              <i data-lucide="trending-down"></i>
            </div>
            <h3>Drastic Savings</h3>
            <p>
              Reduce up to 40% in operational costs by maximizing cargo space utilization.
            </p>
          </div>
          <div class="benefit-card reveal delay-200">
            <div class="benefit-icon">
              <i data-lucide="shield-check"></i>
            </div>
            <h3>Total Security</h3>
            <p>
              International standards of handling and stowage. Your cargo is protected end-to-end.
            </p>
          </div>
          <div class="benefit-card reveal delay-300">
            <div class="benefit-icon">
              <i data-lucide="clock"></i>
            </div>
            <h3>Guaranteed Frequency</h3>
            <p>
              Scheduled daily departures. Don't wait for the truck to fill up, we already have the network ready.
            </p>
          </div>
          <div class="benefit-card reveal delay-400">
            <div class="benefit-icon">
              <i data-lucide="globe"></i>
            </div>
            <h3>24/7 Visibility</h3>
            <p>
              Satellite tracking and automatic notifications. You'll know where your pallet is every second.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it Works -->
    <section id="como-funciona" class="how-it-works bg-alt">
      <div class="container">
        <div class="how-content">
          <div class="how-text">
            <h2 class="section-title">Simplified Process</h2>
            <div class="steps">
              <div class="step reveal-left delay-100">
                <div class="step-num">01</div>
                <div class="step-info">
                  <h3>Scheduled Pickup</h3>
                  <p>
                    We collect your merchandise at your plant or warehouse with millimeter punctuality.
                  </p>
                </div>
              </div>
              <div class="step reveal-left delay-200">
                <div class="step-num">02</div>
                <div class="step-info">
                  <h3>Consolidation at Hub</h3>
                  <p>
                    We integrate your cargo into our optimized routes using space algorithms.
                  </p>
                </div>
              </div>
              <div class="step reveal-left delay-300">
                <div class="step-num">03</div>
                <div class="step-info">
                  <h3>Final Delivery and Evidence</h3>
                  <p>
                    Delivery at destination with immediate digital confirmation and photographic evidence.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="how-image">
            <img
              src="./almacen.avif"
              alt="Warehouse operations"
              class="img-fluid rounded shadow"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Technology -->
    <section id="tecnologia" class="tech-section">
      <div class="container">
        <div class="tech-grid reveal">
          <div class="tech-card glass">
            <img
              src="/logistics_dashboard_mockup.jpg"
              alt="Dashboard Preview"
              class="tech-img reveal-left delay-200"
            />
            <div class="tech-content reveal-right delay-400">
              <h2 class="section-title">Samsara-style Technology</h2>
              <p>
                We are not just transport, we are a technological platform. Our dashboard allows you to:
              </p>
              <ul class="tech-list">
                <li>Real-time tracking with 5-meter precision.</li>
                <li>Smart alerts for route deviation or delays.</li>
                <li>
                  Instant access to documentation (Waybill, Packing List).
                </li>
                <li>Analytics dashboard and KPIs for your shipments.</li>
              </ul>
              <a href="/dashboard" class="btn btn-primary"
                >Explore Demo Dashboard</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quotation Form -->
    <section id="cotiza" class="quote-section">
      <div class="container narrow reveal">
        <div class="quote-card shadow-lg">
          <h2 class="text-center">Calculate Your Savings</h2>
          <p class="text-center text-muted">
            Get an estimated quote in seconds.
          </p>

          <form class="quote-form">
            <div class="form-group">
              <label>Corporate Email</label>
              <input type="email" placeholder="example@company.com" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Origin</label>
                <select>
                  <option>CDMX</option>
                  <option>Monterrey</option>
                  <option>Guadalajara</option>
                  <option>Nuevo Laredo</option>
                </select>
              </div>
              <div class="form-group">
                <label>Destination</label>
                <select>
                  <option>Nuevo Laredo</option>
                  <option>Querétaro</option>
                  <option>Veracruz</option>
                  <option>San Luis Potosí</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Total Weight (kg)</label>
                <input type="number" placeholder="1000" />
              </div>
              <div class="form-group">
                <label>Dimensions (Pallets)</label>
                <input type="number" placeholder="2" />
              </div>
            </div>

            <div class="quote-result" id="quoteResult" style="display: none;">
              <p>Estimated Price:</p>
              <span class="price">$12,450.00 MXN</span>
              <p class="disclaimer">
                *Subject to change after physical verification.
              </p>
            </div>

            <button type="button" class="btn btn-primary btn-block" id="calcBtn"
              >Calculate and Send Quote</button
            >
          </form>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <div class="container narrow">
        <h2 class="section-title text-center">Frequently Asked Questions</h2>
        <div class="accordion">
          <div class="accordion-item">
            <h3>What is consolidated cargo (LTL)?</h3>
            <p>
              It is a model where your merchandise shares space in a truck with other clients, allowing you to pay only for the space you occupy.
            </p>
          </div>
          <div class="accordion-item">
            <h3>What are the delivery times?</h3>
            <p>
              Depending on the route, our times range between 24 and 72 hours for major domestic routes.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials bg-alt">
      <div class="container text-center">
        <h2 class="section-title">What our clients say</h2>
        <div class="testimonial-card shadow">
          <p>
            "The visibility they give us is impressive. We reduced our incidents by 30% since we migrated to their platform."
          </p>
          <div class="testimonial-user">
            <strong>Eng. Roberto Sánchez</strong>
            <span>Logistics Manager, Mex-Log Corp.</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Simple calculator logic for the prototype
    const calcBtn = document.getElementById("calcBtn");
    const quoteResult = document.getElementById("quoteResult");

    if (calcBtn) {
      calcBtn.addEventListener("click", () => {
        quoteResult.style.display = "block";
        calcBtn.textContent = "Quote sent to your email";
        calcBtn.style.backgroundColor = "var(--color-primary)";
        calcBtn.style.color = "white";
      });
    }
  </script>

  <style>
    .hero {
      height: 85vh;
      background-color: var(--color-primary);
      background-size: cover;
      background-position: center;
      position: relative;
      display: flex;
      align-items: center;
      color: white;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        rgba(0, 26, 61, 0.9) 0%,
        rgba(0, 26, 61, 0.4) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 10;
      max-width: 800px;
    }

    .hero h1 {
      font-size: 3.5rem;
      color: white;
      margin-bottom: 1.5rem;
    }

    .hero p {
      font-size: 1.25rem;
      margin-bottom: 2.5rem;
      color: #d1d5db;
    }

    .hero-actions {
      display: flex;
      gap: 1.5rem;
    }

    .social-proof {
      padding: 3rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .section-tag {
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
    }

    .logo-cloud {
      display: flex;
      justify-content: space-around;
      align-items: center;
      flex-wrap: wrap;
      gap: 2rem;
      opacity: 0.6;
    }

    .mock-logo {
      font-weight: 800;
      font-size: 1.2rem;
      color: var(--color-primary);
      letter-spacing: -0.02em;
    }

    .section-title {
      margin-bottom: 3rem;
      font-size: 2.5rem;
      text-align: center;
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .benefit-card {
      padding: 2.5rem;
      background: white;
      border-radius: var(--radius-lg);
      transition: var(--transition);
      border: 1px solid transparent;
    }

    .benefit-card:hover {
      border-color: var(--color-accent);
      transform: translateY(-5px);
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
    }

    .benefit-icon {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
    }

    .bg-alt {
      background-color: var(--color-bg-alt);
    }

    .how-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .steps {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .step {
      display: flex;
      gap: 1.5rem;
    }

    .step-num {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--color-accent);
      opacity: 0.5;
    }

    .how-image img {
      width: 100%;
      border-radius: var(--radius-lg);
    }

    .tech-section {
      overflow: hidden;
    }

    .tech-card {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
      background: var(--color-primary) !important;
      color: white;
      padding: 4rem;
      border-radius: var(--radius-lg);
      align-items: center;
    }

    .tech-content h2 {
      color: white;
      text-align: left;
    }

    .tech-img {
      width: 100%;
      border-radius: var(--radius-md);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .tech-list {
      list-style: none;
      margin: 2rem 0;
    }

    .tech-list li {
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .tech-list li::before {
      content: "✓";
      color: var(--color-accent);
      font-weight: bold;
    }

    .quote-section {
      background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
    }

    .narrow {
      max-width: 800px;
    }

    .quote-card {
      background: white;
      padding: 3rem;
      border-radius: var(--radius-lg);
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--color-text-muted);
    }

    input,
    select {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      font-family: inherit;
    }

    .btn-block {
      width: 100%;
      margin-top: 1rem;
    }

    .quote-result {
      background: var(--color-bg-alt);
      padding: 1.5rem;
      border-radius: var(--radius-md);
      border-left: 4px solid var(--color-accent);
      margin: 2rem 0;
      text-align: center;
    }

    .price {
      font-size: 2rem;
      font-weight: 800;
      color: var(--color-primary);
      display: block;
      margin: 0.5rem 0;
    }

    .disclaimer {
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    .accordion {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .accordion-item {
      background: white;
      padding: 1.5rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
    }

    .testimonial-card {
      max-width: 600px;
      margin: 0 auto;
      background: white;
      padding: 3rem;
      border-radius: var(--radius-lg);
      position: relative;
    }

    .testimonial-card p {
      font-size: 1.25rem;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .text-center {
      text-align: center;
    }

    @media (max-width: 968px) {
      .hero h1 {
        font-size: 2.5rem;
      }
      .how-content,
      .tech-card {
        grid-template-columns: 1fr;
      }
      .tech-card {
        padding: 2rem;
      }
    }
  </style>
</Layout>
